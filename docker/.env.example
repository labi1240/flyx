# =============================================================================
# Flyx Self-Hosted Docker Environment
# Copy this to docker/.env and fill in your values
# =============================================================================

# ── REQUIRED ────────────────────────────────────────────────────────────────
# TMDB v3 API Key — get a free key at https://www.themoviedb.org/settings/api
# This is the short "API Key" (not the long v4 Read Access Token). Set the SAME
# value in both variables — most calls pass it as ?api_key=.
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_v3_api_key_here
TMDB_API_KEY=your_tmdb_v3_api_key_here

# ── OPTIONAL: TMDB v4 Read Access Token (Bearer) ───────────────────────────────
# The long token on the same TMDB API settings page. Optional — if set, it is
# used for Bearer auth where supported; the v3 key above still covers the rest.
# TMDB_API_ACCESS_TOKEN=your_tmdb_v4_read_access_token_here

# ── OPTIONAL (defaults are auto-generated if left as-is) ───────────────────
# Security secrets — change these to random strings for production use.
# If left as the defaults below, the launcher scripts will auto-generate them.
JWT_SECRET=change-me-to-a-random-64-char-hex-string
SIGNING_SECRET=change-me-to-another-random-string
WATERMARK_SECRET=change-me-watermark-secret
ADMIN_SECRET=change-me-admin-secret

# Allow the admin session cookie over plain HTTP (e.g. http://<vps-ip> before
# you set up HTTPS). Browsers drop "Secure" cookies on HTTP, so without this you
# can't stay logged into /admin. REMOVE (or set false) once you serve over HTTPS.
ALLOW_INSECURE_COOKIES=true

# ── DATABASE (required for IPTV + admin on a VPS) ──────────────────────────
# The app's admin panel, IPTV accounts, feedback, and banners normally use
# Cloudflare D1, which doesn't exist off Cloudflare. Setting this makes those
# features use a local SQLite file instead (stored in the /app/data volume).
# Leave it OFF only if you deploy on Cloudflare with real D1 bindings.
DATABASE_BACKEND=sqlite

# ── OPTIONAL (feature flags) ───────────────────────────────────────────────
# Enable VidSrc provider (set to "true" to enable — use at own risk)
ENABLE_VIDSRC_PROVIDER=false

# ── DEPLOYMENT MODE: app on VPS, all proxying on Cloudflare Workers ──────────
# These NEXT_PUBLIC_* URLs are BUILD-TIME values (baked into the client bundle).
# After changing any of them you MUST rebuild:  docker compose up -d --build
#
# Replace <you> with your workers.dev subdomain. Deploy the workers first:
#   npm run deploy:media-proxy   # -> media-proxy.<you>.workers.dev
#   npm run deploy:sync-worker   # -> flyx-sync.<you>.workers.dev   (needs D1)
#   npm run deploy:dlhd          # -> dlhd.<you>.workers.dev        (optional)
#
# With all of these set, the local Bun proxy is unused — turn it off below.
NEXT_PUBLIC_CF_STREAM_PROXY_URL=https://media-proxy.<you>.workers.dev/stream
NEXT_PUBLIC_CF_TV_PROXY_URL=https://media-proxy.<you>.workers.dev
NEXT_PUBLIC_DLHD_WORKER_URL=https://dlhd.<you>.workers.dev
NEXT_PUBLIC_CDN_LIVE_WORKER_URL=https://media-proxy.<you>.workers.dev/cdn-live
NEXT_PUBLIC_CF_SYNC_URL=https://flyx-sync.<you>.workers.dev/sync
NEXT_PUBLIC_CF_ANALYTICS_WORKER_URL=https://flyx-sync.<you>.workers.dev/analytics
NEXT_PUBLIC_PROXY_URL=https://media-proxy.<you>.workers.dev
NEXT_PUBLIC_CF_TMDB_URL=https://media-proxy.<you>.workers.dev

# Skip the bundled Bun proxy (:8787) — set when all proxying is on Cloudflare.
DISABLE_LOCAL_PROXY=true
